{
  "collectionName": "components_product_gallery_images",
  "info": {
    "displayName": "Gallery Image",
    "icon": "landscape",
    "description": "A single image entry in the product gallery with layout aspect hint"
  },
  "options": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "alt": {
      "type": "string",
      "required": true
    },
    "aspect": {
      "type": "enumeration",
      "enum": ["tall", "wide", "square"],
      "default": "square",
      "required": true
    }
  }
}
