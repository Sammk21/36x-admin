{
  "kind": "collectionType",
  "collectionName": "artist_collaborations",
  "info": {
    "singularName": "artist-collaboration",
    "pluralName": "artist-collaborations",
    "displayName": "Artist Collaboration",
    "description": "Artists and collectives who have collaborated on products"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "handle": {
      "type": "uid",
      "targetField": "title"
    },
    "subtitle": {
      "type": "string"
    },
    "bio": {
      "type": "richtext"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-links",
      "repeatable": false
    },
    "bannerImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "artist_collaborations"
    }
  }
}
