{
  "kind": "collectionType",
  "collectionName": "product_collections",
  "info": {
    "singularName": "product-collection",
    "pluralName": "product-collections",
    "displayName": "Product Collection",
    "description": "Product collections from Medusa"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "medusaId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "handle": {
      "type": "uid",
      "targetField": "title"
    },
    "chapter_number": {
      "type": "integer"
    },
    "chapter_label": {
      "type": "string"
    },
    "chapter_subtitle": {
      "type": "string"
    },
    "comic_strip_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accent_color": {
      "type": "string"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "artist_credit": {
      "type": "string"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "product_collection"
    }
  }
}
